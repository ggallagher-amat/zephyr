	gpio14: gpio@4900e000 {
		compatible = "snps,designware-gpio";
		reg = <0x4900E000 0x1000>;
		ngpios = <8>;
		interrupts = <291 0>,
			     <292 0>,
			     <293 0>,
			     <294 0>,
			     <295 0>,
			     <296 0>,
			     <297 0>,
			     <298 0>;
		gpio-controller;
		#gpio-cells = <2>;
		status = "disabled";
	};
};
